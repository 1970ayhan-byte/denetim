# cp .env.example .env  → değerleri doldur

# Mongo (docker-compose mongo servisi + yerel araçlar)
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=
MONGO_DB=anaokulu_denetim
# Mac’te yerel mongod 27017 dinliyorsa Docker ile çakışır; 27018 kullanıp MONGO_URL portunu eşleştir.
MONGO_PORT=27017

# Prisma / seed / next dev — host’tan bağlanırken (şifre yukarıdakiyle aynı, port MONGO_PORT ile aynı olmalı)
MONGO_URL=mongodb://root:SIFRE@127.0.0.1:27017/anaokulu_denetim?authSource=admin

JWT_SECRET=
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# API POST /api/seed için (varsayılan 123123 — üretimde mutlaka SEED_ACCESS_TOKEN ayarla)
# SEED_ACCESS_TOKEN=

# GET|POST /api/admin/database-export — tüm Mongo verisini JSON (header: x-database-export-token)
# Üretimde güçlü rastgele değer verin; boş bırakılırsa endpoint 503 döner.
# DATABASE_EXPORT_TOKEN=

# İsteğe bağlı
# APP_PORT=3000
