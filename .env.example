# cp .env.example .env  → değerleri doldur

# Prisma / Next.js — PostgreSQL bağlantısı (tek gerekli DB env)
# Yerel Docker: aşağıdaki varsayılan docker-compose ile uyumludur
# Uzak sunucu: postgresql://KULLANICI:SIFRE@host:5432/veritabani
DATABASE_URL=postgresql://denetim:denetim@127.0.0.1:5432/denetim

# Docker Compose içindeki Postgres (host makineden compose çalıştırırken .env ile)
# POSTGRES_USER=denetim
# POSTGRES_PASSWORD=denetim
# POSTGRES_DB=denetim
# POSTGRES_PORT=5432

JWT_SECRET=
NEXT_PUBLIC_BASE_URL=http://localhost:3030
CORS_ORIGINS=http://localhost:3030

# GET|POST /api/admin/database-export — JSON yedek (header: x-database-export-token)
# POST /api/admin/database-import — export JSON’unu yükler; mevcut veriyi siler (aynı header)
# Üretimde güçlü rastgele değer verin; boş bırakılırsa endpoint 503 döner.
# DATABASE_EXPORT_TOKEN=

# İsteğe bağlı
# APP_PORT=3030
