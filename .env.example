# cp .env.example .env  → değerleri doldur

# Mongo (docker-compose mongo servisi + yerel araçlar)
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=
MONGO_DB=anaokulu_denetim
MONGO_PORT=27017

# Prisma / seed / yarn dev — host’tan bağlanırken (şifre yukarıdakiyle aynı)
MONGO_URL=mongodb://root:SIFRE@127.0.0.1:27017/anaokulu_denetim?authSource=admin

JWT_SECRET=
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# API POST /api/seed için (varsayılan 123123 — üretimde mutlaka SEED_ACCESS_TOKEN ayarla)
# SEED_ACCESS_TOKEN=

# İsteğe bağlı
# APP_PORT=3000
