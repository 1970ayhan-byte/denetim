// PostgreSQL + Prisma — https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(uuid())
  phone       String       @unique
  password    String
  name        String
  role        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  inspections Inspection[] @relation("InspectorInspections")
}

model Category {
  id        String     @id @default(uuid())
  name      String
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  questions Question[]
}

model Question {
  id             String             @id @default(uuid())
  categoryId     String
  question       String
  regulationText String             @default("")
  imageUrl       String             @default("")
  order          Int                @default(0)
  penaltyType    String             @default("")
  createdAt      DateTime           @default(now())
  category       Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  answers        InspectionAnswer[]
}

model Package {
  id          String       @id @default(uuid())
  name        String
  price       Float
  description String       @default("")
  features    String       @default("")
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  inspections Inspection[]
  payments    Payment[]
}

model City {
  id                  String       @id @default(uuid())
  name                String       @unique
  travelCost          Float        @default(0)
  accommodationCost   Float        @default(0)
  createdAt           DateTime     @default(now())
  inspections         Inspection[]
  payments            Payment[]
}

model Inspection {
  id                   String             @id @default(uuid())
  schoolName           String
  cityId               String
  district             String             @default("")
  packageId            String
  paymentId            String?
  inspectorId          String?
  status               String             @default("pending")
  schoolContact        String             @default("")
  schoolPhone          String             @default("")
  schoolEmail          String             @default("")
  capacity             String             @default("")
  currentCategoryIndex Int                @default(0)
  currentQuestionIndex Int                @default(0)
  skippedQuestionIds   String[]           @default([])
  createdAt            DateTime           @default(now())
  completedAt          DateTime?
  city                 City               @relation(fields: [cityId], references: [id])
  package              Package            @relation(fields: [packageId], references: [id])
  inspector            User?              @relation("InspectorInspections", fields: [inspectorId], references: [id])
  payment              Payment?           @relation(fields: [paymentId], references: [id])
  answers              InspectionAnswer[]
}

model InspectionAnswer {
  id           String     @id @default(uuid())
  inspectionId String
  questionId   String
  answer       String
  note         String     @default("")
  photos       String     @default("")
  createdAt    DateTime   @default(now())
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  question     Question   @relation(fields: [questionId], references: [id])
}

model Payment {
  id            String       @id @default(uuid())
  amount        Float
  packageId     String
  schoolName    String
  cityId        String
  district      String       @default("")
  contactName   String
  contactPhone  String
  contactEmail  String       @default("")
  taxOffice     String       @default("")
  taxNumber     String       @default("")
  address       String       @default("")
  status        String       @default("pending")
  transactionId String       @default("")
  createdAt     DateTime     @default(now())
  paidAt        DateTime?
  package       Package      @relation(fields: [packageId], references: [id])
  city          City         @relation(fields: [cityId], references: [id])
  inspections   Inspection[]
}

model Message {
  id         String   @id @default(uuid())
  name       String
  schoolName String   @default("")
  phone      String
  type       String
  status     String   @default("new")
  note       String   @default("")
  createdAt  DateTime @default(now())
}

model News {
  id        String   @id @default(uuid())
  title     String
  content   String
  imageUrl  String   @default("")
  keywords  String   @default("")
  slug      String   @unique
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
